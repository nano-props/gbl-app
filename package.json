{
  "name": "gbl-app",
  "version": "0.1.0",
  "description": "GBL — Git Branch List, desktop edition",
  "private": true,
  "type": "module",
  "main": "src/main/main.ts",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c blue,green 'vite build --watch --mode development' 'electron .'",
    "start": "vite build && electron .",
    "build": "bun scripts/build.ts",
    "build:renderer": "vite build",
    "build:electron": "electron-builder",
    "typecheck": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.renderer.json",
    "test": "bun test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "publish": "bun scripts/publish.ts",
    "count-lines": "bun scripts/count-lines.ts",
    "clean": "rm -rf dist release"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.0",
    "@types/bun": "1.3.14",
    "@types/node": "25.7.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "concurrently": "9.2.1",
    "electron": "42.0.1",
    "electron-builder": "26.8.1",
    "prettier": "3.8.3",
    "tailwindcss": "4.3.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vite": "8.0.12"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-tooltip": "1.2.8",
    "clsx": "2.1.1",
    "lucide-react": "1.14.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwind-merge": "3.6.0",
    "use-sync-external-store": "^1.6.0",
    "zustand": "5.0.13"
  }
}
